# Subtensor WS endpoint the UI connects to by default.
# Users can override this per-browser via the RPC settings modal
# (stored in localStorage). The override only applies at runtime;
# this env is the build-time default.
VITE_SUBTENSOR_WS=wss://archive-rocksdb.internal.tao.com

# Genesis hash the UI expects from the RPC. On every API init the
# reported hash is compared against this value and a prominent
# warning is shown on mismatch, protecting voters from accidentally
# reading state from a different chain.
# devnet:  0x077899043eb684c5277b6814a39161f4ce072b45e782e12c81a521c63fb4f3e5
VITE_EXPECTED_GENESIS_HASH=0x077899043eb684c5277b6814a39161f4ce072b45e782e12c81a521c63fb4f3e5

# Faucet backend for drip requests.
VITE_FAUCET_URL=http://localhost:3000

# ──────────────────────────────────────────────────────────────────────
# Proposal configuration.
#
# All VITE_PROPOSAL_* vars are inlined into the bundle at build time —
# they're not served at runtime, so changing them on a live deploy
# requires a rebuild. If a var is unset/empty, the default in
# packages/ui/src/proposal.ts takes over.
# ──────────────────────────────────────────────────────────────────────

# Stable identifier. Embedded in every announce/vote remark prefix,
# so changing it effectively starts a new, isolated proposal.
VITE_PROPOSAL_ID=proposal-1

# Headline shown in the UI.
VITE_PROPOSAL_TITLE=Release to Mainnet (Week of Apr 13)

# Body shown under the title. Limited HTML (<br>, <strong>, <code>) is
# rendered verbatim via dangerouslySetInnerHTML.
VITE_PROPOSAL_DESCRIPTION=Features to be released: <br>- Child hotkeying...

# Comma-separated SS58 addresses allowed to announce + vote. Order is
# irrelevant; the ring sorts deterministically at verify time.
VITE_PROPOSAL_ALLOWED_VOTERS=5CsvRJXuR955WojnGMdok1hbhffZyB4N5ocrv82f3p5A2zVp,5D4gEn5S422dTGR5NJJKZ93FNV6hDmfwDPfxFNgcoVnUkZ4f

# First block the indexer scans. Everything earlier is ignored.
# Per-proposal isolation is achieved by setting a fresh block per
# proposal — announce remarks from older proposals don't leak in.
VITE_PROPOSAL_START_BLOCK=7962121

# SS58 address of the coordinator. Its only protocol power is to
# publish the `start` remark that opens the voting phase. Must match
# COORDINATOR_ADDRESS in the faucet's .env.
VITE_PROPOSAL_COORDINATOR=5Ff9wuYWk2r8qKutC5NKGBqEVY2rty5JXCBTXz5Tm7ndiWwQ
