# Subtensor WS endpoint the UI connects to by default.
# Users can override this per-browser via the RPC settings modal
# (stored in localStorage). The override only applies at runtime;
# this env is the build-time default.
VITE_SUBTENSOR_WS=wss://archive-rocksdb.internal.tao.com

# Genesis hash the UI expects from the RPC. On every API init the
# reported hash is compared against this value and a prominent
# warning is shown on mismatch, protecting voters from accidentally
# reading state from a different chain.
# devnet:  0x077899043eb684c5277b6814a39161f4ce072b45e782e12c81a521c63fb4f3e5
VITE_EXPECTED_GENESIS_HASH=0x077899043eb684c5277b6814a39161f4ce072b45e782e12c81a521c63fb4f3e5

# Faucet backend for drip requests.
VITE_FAUCET_URL=http://localhost:3000
